{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-opus-4-7[1m]",
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "session-report@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "mcpServers": {
    "filesystem-arthas": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/patrickmoorhead/arthas"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(bun:*)",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git push origin:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git stash:*)",
      "Bash(git remote -v)",
      "Bash(git remote get-url:*)",
      "Bash(git worktree:*)",
      "Bash(git ls-tree:*)",
      "Bash(git show:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(jq:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(which:*)",
      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Bash(ollama list)",
      "Bash(ollama ps)",
      "Bash(ollama pull:*)",
      "Bash(ollama show:*)",
      "Bash(/Users/patrickmoorhead/.bun/bin/bun:*)",
      "Read(/Users/patrickmoorhead/arthas/**)",
      "Edit(/Users/patrickmoorhead/arthas/**)",
      "Write(/Users/patrickmoorhead/arthas/**)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(curl:*--data*)",
      "Read(/Users/patrickmoorhead/.ssh/**)",
      "Read(/Users/patrickmoorhead/.aws/credentials)",
      "Read(/Users/patrickmoorhead/arthas/.env)",
      "Read(/Users/patrickmoorhead/arthas/.env.local)",
      "Read(/Users/patrickmoorhead/arthas/.env.*.local)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "test \"${CLAUDE_FILE_PATH##*.}\" = \"ts\" && cd /Users/patrickmoorhead/arthas && bun tsc --noEmit --project packages/opencode/tsconfig.json 2>&1 | head -20 || true"
          }
        ]
      }
    ]
  },
  "env": {
    "ARTHAS_REPO_ROOT": "/Users/patrickmoorhead/arthas",
    "ARTHAS_UPSTREAM": "https://github.com/sst/opencode"
  }
}
